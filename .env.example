# JWT
JWT_SECRET=gere-com-node-e-console.log-require-crypto-.randomBytes-32-.toString-hex
JWT_EXPIRY=7d

# Database
DATABASE_URL=postgresql://usuario:senha@localhost:5432/ofertarelay

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=seu_access_token_aqui
MERCADOPAGO_WEBHOOK_SECRET=gere-com-node-e-console.log-require-crypto-.randomBytes-32-.toString-hex
MERCADOPAGO_API_URL=https://api.mercadopago.com

# Webhook
WEBHOOK_RATE_LIMIT=100
WEBHOOK_TIMEOUT_MS=30000
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_CLEANUP_DAYS=90

# Notificações
ENVIAR_EMAIL_CONFIRMACAO_PAGAMENTO=true
EMAIL_ADMIN=admin@ofertarelay.com

# Evolution API (WhatsApp)
EVOLUTION_API_KEY=sua-api-key-aqui
EVOLUTION_API_URL=https://evolution-api.com

# Bull / Redis queues
BULL_SYNC_QUEUE=whatsapp-sync

# n8n Integration
N8N_WEBHOOK_SECRET=gere-com-node-e-console.log-require-crypto-.randomBytes-32-.toString-hex
N8N_RATE_LIMIT_CONFIGURACOES=10
N8N_RATE_LIMIT_GRUPOS=10
N8N_RATE_LIMIT_LOG=100
N8N_REQUEST_TIMEOUT_MS=30000
N8N_LOG_REQUESTS=true
N8N_LOG_LEVEL=info
